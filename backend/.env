NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/exir_healthcare

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=24h

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# AI Service
AI_SERVICE_URL=http://localhost:8001
# ESP32 IV Regulator Hardware — WiFi mode
# The ESP32 connects to this server automatically over WiFi.
# Make sure the ESP32 firmware has the correct WiFi credentials and points to this PC's IP.
ESP32_CONNECTION=wifi
