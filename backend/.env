NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/exir_healthcare

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=24h

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ESP32 IV Regulator Hardware
# ESP32_CONNECTION: 'serial' (USB) or 'wifi' (future)
# ESP32_SERIAL_PORT: COM3 / COM4 on Windows; /dev/ttyUSB0 or /dev/ttyACM0 on Linux/Mac
ESP32_CONNECTION=serial
ESP32_SERIAL_PORT=COM9
ESP32_BAUD_RATE=115200
